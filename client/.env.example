# ================= CẤU HÌNH HPC RECEIVABLE =================
# Copy file này thành ".env" và điền giá trị thật.

# Chế độ dữ liệu:
#   local     = chạy thử ở máy (đọc seed.json, lưu trình duyệt) — KHÔNG cần Firebase
#   firestore = dùng Firebase thật (production)
VITE_DATA_BACKEND=local

# --- Khóa Firebase (IT điền khi VITE_DATA_BACKEND=firestore) ---
# Lấy tại: Firebase Console > Project settings > General > Your apps > SDK setup
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_SENDER_ID=
VITE_FB_APP_ID=

# Link quay lại HP CONS Portal (nút "← Về HP CONS Portal")
VITE_PORTAL_URL=
